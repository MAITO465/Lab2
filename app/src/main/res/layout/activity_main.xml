<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculateur de Taxe Foncière"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center" />

        <EditText
            android:id="@+id/et_metrage_surface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dimension en m²"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/et_quantite_pieces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre total de pièces"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cb_option_piscine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="La propriété possède une piscine"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_generer_calcul"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Estimation des taxes"
            android:backgroundTint="#1A237E" />

        <TextView
            android:id="@+id/tv_affichage_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:padding="15dp"
            android:background="#EEEEEE"
            android:text="Résultat : 0.00 DH"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="italic" />

    </LinearLayout>
</ScrollView>